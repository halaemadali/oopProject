<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<AnchorPane prefHeight="520.0" prefWidth="520.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controllers.ReceptionistLoginController"
            style="-fx-background-color: #f0f4f8;">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <children>

        <!-- ── Top accent bar ── -->
        <AnchorPane layoutX="0.0" layoutY="0.0" prefHeight="8.0" prefWidth="520.0"
                    style="-fx-background-color: #e06d67;" />

        <!-- ── Card container ── -->
        <VBox layoutX="60.0" layoutY="60.0" prefWidth="400.0" spacing="0"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 14, 0, 0, 4);">

            <padding>
                <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
            </padding>

            <!-- Icon placeholder + Title -->
            <Label text="🏨" style="-fx-font-size: 36px;" />

            <Region prefHeight="8.0"/>

            <Label text="Staff Login" styleClass="title-label"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c2c2c;"/>

            <Label text="Receptionist Portal"
                   style="-fx-font-size: 13px; -fx-text-fill: #888888; -fx-padding: 0 0 24 0;"/>

            <!-- Username -->
            <Label text="Username" styleClass="field-label"/>
            <Region prefHeight="4.0"/>
            <TextField fx:id="usernameField"
                       promptText="Enter your username"
                       styleClass="input-field"/>

            <Region prefHeight="16.0"/>

            <!-- Password -->
            <Label text="Password" styleClass="field-label"/>
            <Region prefHeight="4.0"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           styleClass="input-field"/>

            <Region prefHeight="8.0"/>

            <!-- Status label -->
            <Label fx:id="statusLabel" text="" wrapText="true" maxWidth="320.0"
                   style="-fx-font-size: 13px; -fx-text-fill: #e74c3c;"/>

            <Region prefHeight="20.0"/>

            <!-- Login button -->
            <Button text="Login"
                    styleClass="btn-main"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    prefHeight="42.0"/>

            <Region prefHeight="12.0"/>

            <!-- Back link -->
            <HBox alignment="CENTER">
                <Button text="← Back to Main Login"
                        styleClass="btn-secondary"
                        onAction="#handleBack"
                        prefHeight="36.0"
                        prefWidth="200.0"/>
            </HBox>

        </VBox>

        <!-- ── Bottom role badge ── -->
        <Label text="RECEPTIONIST ACCESS ONLY"
               layoutX="140.0" layoutY="470.0"
               style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa; -fx-font-weight: bold;"/>

    </children>
</AnchorPane>
