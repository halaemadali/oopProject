<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="620" prefWidth="900" style="-fx-background-color:#f4f4f4;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.CancelReservationController">

    <!-- TOP HEADER -->
    <top>
        <VBox alignment="CENTER" prefHeight="77.0" prefWidth="900.0" spacing="6" style="-fx-background-color:#2c3e50;">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill:white; -fx-font-size:28px; -fx-font-weight:bold;" text="Cancel a Reservation" />

            <Label fx:id="welcomeLabel" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill:#bdc3c7; -fx-font-size:13px;" text="" />
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="12">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#2c3e50;" text="Select a reservation to cancel" />

            <TableView fx:id="cancelTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colRoom" prefWidth="90" text="Room No." />
                    <TableColumn fx:id="colType" prefWidth="100" text="Type" />
                    <TableColumn fx:id="colCheckin" prefWidth="120" text="Check-in" />
                    <TableColumn fx:id="colCheckout" prefWidth="120" text="Check-out" />
                    <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
                </columns>
            </TableView>

            <Label fx:id="statusLabel" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill:#e74c3c; -fx-font-size:13px;" text="" />
        </VBox>
    </center>

    <!-- BOTTOM BUTTONS -->
    <bottom>
        <HBox alignment="CENTER" spacing="16" style="-fx-background-color:#ecf0f1; -fx-border-color:#bdc3c7; -fx-border-width:1 0 0 0;">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <Button onAction="#handleBack" prefHeight="38" prefWidth="160" style="-fx-background-color:white; -fx-border-color:#2c3e50;                            -fx-border-width:1.5; -fx-border-radius:6;                            -fx-background-radius:6; -fx-cursor:hand;" text="← Back" />

            <Button onAction="#handleConfirmCancel" prefHeight="38" prefWidth="200" style="-fx-background-color:#c0392b; -fx-text-fill:white;                            -fx-font-weight:bold; -fx-background-radius:6; -fx-cursor:hand;" text="Confirm Cancel" />
        </HBox>
    </bottom>

</BorderPane>
