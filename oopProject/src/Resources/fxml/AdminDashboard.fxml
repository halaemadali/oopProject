<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane prefHeight="700.0" prefWidth="950.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controllers.AdminDashboardController"
            style="-fx-background-color: #f0f4f8;">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- ══════════════════ TOP HEADER ══════════════════ -->
    <top>
        <VBox style="-fx-background-color: #1a1a2e;" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="24.0" bottom="16.0" left="24.0"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label text="🏨  Admin Dashboard"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Label text="Hotel Management System — Admin Panel"
                                       style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"/>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <VBox alignment="CENTER_RIGHT" spacing="2.0">
                            <children>
                                <Label text="Logged in as:"
                                       style="-fx-font-size: 11px; -fx-text-fill: #aaaaaa;"/>
                                <Label fx:id="lblAdmin"
                                       text="—"
                                       style="-fx-font-size: 14px; -fx-text-fill: #e06d67; -fx-font-weight: bold;"/>
                            </children>
                        </VBox>

                        <Button text="Logout"
                                styleClass="btn-secondary"
                                onAction="#handleLogout"
                                prefHeight="34.0"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <!-- ══════════════════ LEFT SIDEBAR ══════════════════ -->
    <left>
        <VBox prefWidth="210.0" spacing="10.0"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="24.0" right="16.0" bottom="24.0" left="16.0"/>
            </padding>
            <children>

                <Label text="MANAGEMENT"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>
                <Separator/>

                <Button text="🏠  Add Room"
                        fx:id="btnAddRoom"
                        maxWidth="Infinity" prefHeight="38.0"
                        styleClass="btn-main"
                        onAction="#handleShowAddRoom"/>

                <Button text="📋  Add Room Type"
                        fx:id="btnAddRoomType"
                        maxWidth="Infinity" prefHeight="38.0"
                        styleClass="btn-secondary"
                        onAction="#handleShowAddRoomType"/>

                <Button text="✨  Add Amenity"
                        fx:id="btnAddAmenity"
                        maxWidth="Infinity" prefHeight="38.0"
                        styleClass="btn-secondary"
                        onAction="#handleShowAddAmenity"/>

                <Button text="👤  Add Receptionist"
                        fx:id="btnAddReceptionist"
                        maxWidth="Infinity" prefHeight="38.0"
                        styleClass="btn-secondary"
                        onAction="#handleShowAddReceptionist"/>

            </children>
        </VBox>
    </left>

    <!-- ══════════════════ CENTER — Form Panels ══════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;"
                    BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="0.0">
                    <padding>
                        <Insets top="24.0" right="28.0" bottom="24.0" left="28.0"/>
                    </padding>
                    <children>

                        <!-- ── Status label (shared) ── -->
                        <Label fx:id="statusLabel"
                               text=""
                               wrapText="true"
                               maxWidth="Infinity"
                               style="-fx-font-size: 13px;"/>

                        <Region prefHeight="10.0"/>

                        <!-- ════════ PANEL 1 — Add Room ════════ -->
                        <VBox fx:id="panelAddRoom"
                              spacing="14.0" visible="true" managed="true"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);">
                            <padding>
                                <Insets top="22.0" right="24.0" bottom="22.0" left="24.0"/>
                            </padding>
                            <children>

                                <Label text="🏠  Add New Room"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c2c2c;"/>
                                <Separator/>

                                <!-- Row 1: Room Number + Floor -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Room Number" styleClass="field-label"/>
                                                <TextField fx:id="roomNumberField"
                                                           promptText="e.g. 201"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Floor (0 – 5)" styleClass="field-label"/>
                                                <TextField fx:id="roomFloorField"
                                                           promptText="e.g. 2"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Row 2: Room Type + View -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Room Type" styleClass="field-label"/>
                                                <ComboBox fx:id="roomTypeCombo"
                                                          promptText="Select type"
                                                          maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="View" styleClass="field-label"/>
                                                <ComboBox fx:id="roomViewCombo"
                                                          promptText="Select view"
                                                          maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="Add Room"
                                                styleClass="btn-main"
                                                onAction="#handleAddRoom"
                                                prefHeight="36.0" prefWidth="150.0"/>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                        <Region prefHeight="18.0"/>

                        <!-- ════════ PANEL 2 — Add Room Type ════════ -->
                        <VBox fx:id="panelAddRoomType"
                              spacing="14.0" visible="false" managed="false"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);">
                            <padding>
                                <Insets top="22.0" right="24.0" bottom="22.0" left="24.0"/>
                            </padding>
                            <children>

                                <Label text="📋  Add New Room Type"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c2c2c;"/>
                                <Separator/>

                                <!-- Row: Category + Capacity -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Category Name" styleClass="field-label"/>
                                                <TextField fx:id="rtCategoryField"
                                                           promptText="e.g. Penthouse"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Capacity" styleClass="field-label"/>
                                                <TextField fx:id="rtCapacityField"
                                                           promptText="e.g. 5"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Base Price -->
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Base Price ($)" styleClass="field-label"/>
                                        <TextField fx:id="rtPriceField"
                                                   promptText="e.g. 1500"
                                                   styleClass="input-field"
                                                   prefWidth="200.0"/>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="Add Room Type"
                                                styleClass="btn-main"
                                                onAction="#handleAddRoomType"
                                                prefHeight="36.0" prefWidth="150.0"/>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                        <Region prefHeight="18.0"/>

                        <!-- ════════ PANEL 3 — Add Amenity ════════ -->
                        <VBox fx:id="panelAddAmenity"
                              spacing="14.0" visible="false" managed="false"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);">
                            <padding>
                                <Insets top="22.0" right="24.0" bottom="22.0" left="24.0"/>
                            </padding>
                            <children>

                                <Label text="✨  Add New Amenity"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c2c2c;"/>
                                <Separator/>

                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Amenity Name" styleClass="field-label"/>
                                                <TextField fx:id="amenityNameField"
                                                           promptText="e.g. Jacuzzi"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Price ($)" styleClass="field-label"/>
                                                <TextField fx:id="amenityPriceField"
                                                           promptText="e.g. 200"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="Add Amenity"
                                                styleClass="btn-main"
                                                onAction="#handleAddAmenity"
                                                prefHeight="36.0" prefWidth="150.0"/>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                        <Region prefHeight="18.0"/>

                        <!-- ════════ PANEL 4 — Add Receptionist ════════ -->
                        <VBox fx:id="panelAddReceptionist"
                              spacing="14.0" visible="false" managed="false"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);">
                            <padding>
                                <Insets top="22.0" right="24.0" bottom="22.0" left="24.0"/>
                            </padding>
                            <children>

                                <Label text="👤  Add New Receptionist"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c2c2c;"/>
                                <Separator/>

                                <!-- Row 1: Username + Password -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Username" styleClass="field-label"/>
                                                <TextField fx:id="recepUsernameField"
                                                           promptText="e.g. receptionist3"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Password" styleClass="field-label"/>
                                                <PasswordField fx:id="recepPasswordField"
                                                               promptText="Min. 6 characters"
                                                               styleClass="input-field"
                                                               maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Row 2: Date of Birth + Working Hours -->
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Date of Birth" styleClass="field-label"/>
                                                <DatePicker fx:id="recepDobPicker"
                                                            promptText="Select date"
                                                            maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Working Hours / Day" styleClass="field-label"/>
                                                <TextField fx:id="recepHoursField"
                                                           promptText="e.g. 8"
                                                           styleClass="input-field"
                                                           maxWidth="Infinity"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="Add Receptionist"
                                                styleClass="btn-main"
                                                onAction="#handleAddReceptionist"
                                                prefHeight="36.0" prefWidth="160.0"/>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
