<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<?import java.net.URL?>
<AnchorPane prefHeight="500.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.LoginController">


   <stylesheets>
      <URL value="@styles.css"/>
   </stylesheets>
   <children>
      <AnchorPane layoutX="-2.0" layoutY="-2.0" prefHeight="400.0" prefWidth="600.0">
         <children>
            <Label layoutX="150.0" layoutY="40.0" text="Hotel Login" styleClass="title-label" />
            <TextField fx:id="loginUsernameField" layoutX="80.0" layoutY="130.0"  styleClass="input-field" />
            <PasswordField fx:id="loginPasswordField" layoutX="80.0" layoutY="200.0" styleClass="input-field"  />
            <Button  layoutX="80.0" layoutY="280.0"  mnemonicParsing="false"  styleClass="btn-main" onAction="#handleLogin" text="Login" />
            <Button layoutX="80.0" layoutY="350.0" mnemonicParsing="false" styleClass="btn-secondary" onAction="#handleGoToRegister" text="Sign Up" />
            <Label fx:id="loginStatusLabel" layoutX="80.0" layoutY="400.0" text="" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
